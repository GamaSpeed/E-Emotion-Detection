# ──────────────────────────────────────────────────────────────────
# .env.example — Copier en .env et remplir les valeurs
# NE PAS versionner le fichier .env réel (ajouter à .gitignore)
# ──────────────────────────────────────────────────────────────────

# ── Base de données ────────────────────────────────────────────────
# Local VirtualBox (SQLite — fichier unique, zéro configuration)
DATABASE_URL=sqlite:///./data/edusense.db

# Google Cloud SQL (PostgreSQL) — décommenter pour la prod
# DATABASE_URL=postgresql://edusense_user:PASSWORD@/edusense?host=/cloudsql/PROJECT:REGION:INSTANCE

# ── Authentification JWT ───────────────────────────────────────────
# Local : une clé quelconque suffit pour les tests
JWT_SECRET_KEY=local-dev-secret-changeme
JWT_EXPIRE_HOURS=24

# ── Modèle IA ─────────────────────────────────────────────────────
CONFIG_PATH=configs/config.yaml
CHECKPOINT_PATH=notebooks/outputs/checkpoints/best_model.pt
DEVICE=cpu
# DEVICE=cuda   # si GPU disponible

# ── Frontend (React) ───────────────────────────────────────────────
# Local VirtualBox : remplacer par l'IP de la VM serveur
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# Google Cloud : utiliser wss:// avec le domaine Cloud Run
# VITE_API_URL=https://backend-xxxx-uc.a.run.app
# VITE_WS_URL=wss://backend-xxxx-uc.a.run.app

# ── Google Cloud (remplir seulement pour le déploiement GCP) ──────
# GCP_PROJECT_ID=mon-projet-gcp
# GCP_REGION=us-central1
# CLOUD_SQL_INSTANCE=mon-projet-gcp:us-central1:edusense-db
